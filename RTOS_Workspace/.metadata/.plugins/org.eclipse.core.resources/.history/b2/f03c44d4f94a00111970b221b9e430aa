void change_access_level_unpriv(){
	//Read
	__asm volatile ("MSR R0,CONTROL");// we got the value into R0, MSR is used because CONTROL is a special purpose register
	//Modify: For this we can use OR operation
	__asm volatile ("ORR R0,R0,#0x01"); // R0 | 0x01, we have given immediate value #0x01
	//Write back
	__asm volatile ("MSR CONTROL,RO");
}

